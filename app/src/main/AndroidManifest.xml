<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PedeJa"
        android:usesCleartextTraffic="true">

        <activity android:name=".ui.SplashActivity" android:exported="true" android:theme="@style/Theme.PedeJa.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <activity android:name=".ui.LoginActivity" android:exported="false"/>
        <activity android:name=".ui.HomeActivity" android:exported="false"/>
        <activity android:name=".ui.CategoriasActivity" android:exported="false"/>
        <activity android:name=".ui.ProdutosActivity" android:exported="false"/>
        <activity android:name=".ui.DetalheProdutoActivity" android:exported="false"/>
        <activity android:name=".ui.CarrinhoActivity" android:exported="false"/>
        <activity android:name=".ui.EnderecoActivity" android:exported="false"/>
        <activity android:name=".ui.ResumoPedidoActivity" android:exported="false"/>
        <activity android:name=".ui.ConfirmacaoActivity" android:exported="false"/>
        <activity android:name=".ui.HistoricoActivity" android:exported="false"/>
        <activity android:name=".ui.DetalhePedidoActivity" android:exported="false"/>

    </application>

</manifest>
