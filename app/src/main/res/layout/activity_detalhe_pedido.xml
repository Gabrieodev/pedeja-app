<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/cinza_fundo">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/amarelo"
        android:padding="16dp"
        android:paddingTop="36dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnVoltarDetPed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textColor="@color/branco"
            android:layout_marginEnd="16dp"/>

        <TextView
            android:id="@+id/tvTituloDetPed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pedido #12345"
            android:textColor="@color/branco"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card info -->
            <androidx.cardview.widget.CardView
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@color/branco">

                    <TextView
                        android:id="@+id/tvDataDetPed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="25/05/2024 • 19:30"
                        android:textColor="@color/cinza_texto"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Itens"
                        android:textColor="@color/preto"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/llItensDetPed"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#EEEEEE"
                        android:layout_marginVertical="12dp"/>

                    <!-- Taxa + Total -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Taxa de entrega" android:textColor="@color/cinza_texto" android:textSize="14sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R$ 5,00" android:textColor="@color/cinza_texto" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Total" android:textColor="@color/preto" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:id="@+id/tvTotalDetPed" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R$ 40,80" android:textColor="@color/preto" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status"
                        android:textColor="@color/cinza_texto"
                        android:textSize="13sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvStatusDetPed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entregue"
                        android:textColor="@color/verde"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
