<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/branco">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/amarelo"
        android:padding="16dp"
        android:paddingTop="36dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnVoltarEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:text="←"
            android:textColor="@color/branco"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Endereço de entrega"
            android:textColor="@color/branco"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome completo"
                android:textColor="@color/cinza_texto"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etNomeEnd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Pedro Silva"
                android:inputType="textPersonName"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_border"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Endereço"
                android:textColor="@color/cinza_texto"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etEnderecoRua"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Rua das Flores, 123"
                android:inputType="textPostalAddress"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_border"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bairro"
                android:textColor="@color/cinza_texto"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etBairro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Centro"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_border"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cidade"
                android:textColor="@color/cinza_texto"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etCidade"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="São Paulo - SP"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_border"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Telefone"
                android:textColor="@color/cinza_texto"
                android:textSize="12sp"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etTelefone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="(11) 99999-9999"
                android:inputType="phone"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_border"/>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnSalvarEnd"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Salvar e continuar"
        android:textColor="@color/branco"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/btn_amarelo_arredondado"
            android:backgroundTint="@null"
        android:layout_margin="16dp"/>

</LinearLayout>
